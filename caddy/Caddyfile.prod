:80 {
  encode zstd gzip

  handle_path /static/* {
    root * /srv/static
    file_server
  }

  handle_path /media/* {
    root * /srv/media
    file_server
  }

  @backend path /api* /admin*
  handle @backend {
    reverse_proxy web:8000 {
      header_up X-Forwarded-Proto https
    }
  }

  root * /srv/frontend
  try_files {path} /index.html
  file_server
}
