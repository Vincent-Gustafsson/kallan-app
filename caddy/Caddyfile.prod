:80 {
  encode zstd gzip

  handle_path /static/* {
    root * /srv/static
    file_server
  }

  handle_path /media/* {
    root * /srv/media
    file_server
  }

  @django path /api/* /admin/*
  handle @django {
    reverse_proxy web:8000 {
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-For {remote}
    }
  }

  root * /srv/frontend
  try_files {path} /index.html
  file_server
}
